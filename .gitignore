.DS_Store
node_modules/
dist/

# uv-managed sidecar virtualenv + caches — never global, never committed.
sidecar/.venv/
sidecar/.trt-cache/
**/__pycache__/

# Source archives + unzipped intermediates — large, regenerable, never deployed.
# The shipped assets are the merged GLBs in public/models/ (committed).
assets/bipeds/*.zip
public/bipeds/

# Pose ONNX inference models — large (rtmw3d ~352MB > GitHub 100MB limit) and NOT
# regenerable from this repo: they're exported by the separate `object-detect`
# project (not vendored here). Obtain them via file transfer and drop into
# public/inference/ (see README "Inference models"). `npm run check:models`
# verifies they're present. Committed character GLBs in public/models/ stay.
public/inference/

# camera debug snapshots (webcam frames — do not commit, privacy)
cam-*.jpg
