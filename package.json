{
  "name": "mesh-vj-layer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "predev": "node scripts/check-models.mjs",
    "build": "vite build",
    "prebuild": "node scripts/check-models.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "check:models": "node scripts/check-models.mjs",
    "sidecar": "uv run --project sidecar python sidecar/pose_sidecar.py",
    "sidecar:cuda": "uv run --project sidecar --with tensorrt-cu12==10.9.0.34 --with tensorrt-cu12-libs==10.9.0.34 python sidecar/pose_sidecar.py",
    "sidecar:cameras": "uv run --project sidecar python sidecar/pose_sidecar.py --list-cameras",
    "cam:test": "uv run --project sidecar python sidecar/cam_test.py",
    "prepare:bipeds": "node scripts/prepare-bipeds.mjs",
    "optimize:bipeds": "node scripts/optimize-bipeds.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "0.185.0",
    "vite": "8.1.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "vitest": "^4.1.9"
  }
}
