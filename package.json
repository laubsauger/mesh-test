{
  "name": "mesh-vj-layer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "predev": "node scripts/check-models.mjs",
    "build": "vite build",
    "prebuild": "node scripts/check-models.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "check:models": "node scripts/check-models.mjs",
    "sidecar": "uv run --project sidecar python sidecar/pose_sidecar.py",
