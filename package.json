    "prepare:bipeds": "node scripts/prepare-bipeds.mjs",
    "optimize:bipeds": "node scripts/optimize-bipeds.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "onnxruntime-web": "^1.27.0",
    "three": "0.185.0",
    "vite": "8.1.0"
  },
